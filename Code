html{scroll-behavior:smooth}
body{font-family:Georgia,serif;background:var(--cream);color:var(--ink);line-height:1.6}
a{color:var(--teal)}
nav{position:fixed;top:0;left:0;right:0;z-index:100;background:rgba(245,237,224,.96);backdrop-filter:blur(10px);border-bottom:1px solid rgba(10,124,124,.15);display:flex;justify-content:space-between;align-items:center;padding:14px 32px}
.logo{color:var(--teal);font-family:Georgia,serif;font-size:1.05rem;font-weight:700;text-decoration:none}
.nav-btn{background:var(--teal);color:#fff;font-family:Arial,sans-serif;font-size:.82rem;font-weight:700;letter-spacing:.08em;text-transform:uppercase;text-decoration:none;padding:11px 24px;border-radius:3px}
.nav-btn:hover{background:var(--teal-dark)}
