.field{margin-bottom:18px}
label{display:block;font-family:Arial,sans-serif;font-size:.76rem;letter-spacing:.1em;text-transform:uppercase;color:#4a5858;margin-bottom:6px;font-weight:700}
input[type=text],input[type=email],input[type=number],textarea,select{width:100%;padding:12px 14px;border:1px solid #d0d8d8;border-radius:3px;font-family:Georgia,serif;font-size:1rem;background:#fafcfc}
input:focus,textarea:focus,select:focus{outline:none;border-color:var(--teal)}
textarea{resize:vertical;min-height:70px}
.check-row{display:flex;align-items:flex-start;gap:10px;background:var(--teal-light);padding:14px 16px;border-radius:3px;margin-bottom:22px;cursor:pointer}
.check-row input{margin-top:3px;accent-color:var(--teal);width:auto}
.check-row-text{font-family:Arial,sans-serif;font-size:.92rem;color:var(--teal-dark)}
.check-row-text strong{display:block;letter-spacing:.08em;text-transform:uppercase;font-size:.76rem;margin-bottom:3px;color:var(--teal)}
.qty-row{display:grid;grid-template-columns:1fr 1fr;gap:14px}
.total-row{display:flex;justify-content:space-between;align-items:center;padding:18px 0;margin:14px 0 22px;border-top:1px solid #e0e8e8;border-bottom:1px solid #e0e8e8}
.total-label{font-family:Arial,sans-serif;font-size:.82rem;letter-spacing:.12em;text-transform:uppercase;color:#4a5858;font-weight:700}
.total-price{font-family:Georgia,serif;font-size:1.6rem;color:var(--teal);font-weight:700}
.btn-submit{width:100%;background:var(--teal);color:#fff;font-family:Arial,sans-serif;font-size:1rem;font-weight:700;letter-spacing:.1em;text-transform:uppercase;padding:18px;border:none;border-radius:3px;cursor:pointer}
.btn-submit:hover{background:var(--teal-dark)}
.form-note{font-family:Arial,sans-serif;font-size:.78rem;color:#6a7878;text-align:center;margin-top:14px;line-height:1.5}
footer{background:#0a1818;color:#88a8a8;text-align:center;padding:36px 24px;font-family:Arial,sans-serif;font-size:.84rem}
