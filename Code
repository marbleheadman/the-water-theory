.hero-tagline{font-family:Georgia,serif;font-size:clamp(1.6rem,3.3vw,2.2rem);line-height:1.25;font-style:italic;margin-bottom:22px}
.hero-sub{font-size:1.05rem;color:#3d5050;margin-bottom:32px;max-width:460px}
.price-row{display:flex;align-items:center;gap:14px;margin-bottom:28px;flex-wrap:wrap}
.price{font-family:Georgia,serif;font-size:2rem;font-weight:700}
.price-note{font-family:Arial,sans-serif;font-size:.85rem;color:#6a7878}
.signed-badge{display:inline-flex;align-items:center;gap:6px;background:var(--teal);color:#fff;font-family:Arial,sans-serif;font-size:.72rem;font-weight:700;letter-spacing:.12em;text-transform:uppercase;padding:7px 13px;border-radius:3px}
