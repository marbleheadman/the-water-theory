.btn-primary:hover{background:var(--teal-dark)}
.synopsis{background:#fff;padding:90px 32px}
.container{max-width:720px;margin:0 auto}
.section-label{font-family:Arial,sans-serif;font-size:.72rem;letter-spacing:.25em;text-transform:uppercase;color:var(--teal);margin-bottom:14px;font-weight:700;text-align:center}
h2{font-family:Georgia,serif;font-size:clamp(1.7rem,3.3vw,2.2rem);line-height:1.25;margin-bottom:30px;text-align:center;font-style:italic;font-weight:400}
